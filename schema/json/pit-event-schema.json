{
  "$id": "https://schemas.pit.io/json/pit-event-schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["event_id", "event_name", "tenant_id", "app_id", "device_id", "ts_client"],
  "properties": {
    "event_id": {"type": "string", "minLength": 8, "maxLength": 64},
    "event_name": {"type": "string", "maxLength": 64},
    "tenant_id": {"type": "string", "maxLength": 32, "description": "organization_id; multi-tenant isolation key"},
    "app_id": {"type": "string", "maxLength": 64, "description": "game_id + environment"},
    "user_id": {"type": ["string", "null"], "maxLength": 64},
    "device_id": {"type": "string", "maxLength": 64},
    "session_id": {"type": ["string", "null"], "maxLength": 64},
    "ts_client": {"oneOf": [ {"type": "string", "format": "date-time"}, {"type": "number"} ]},
    "platform": {"type": ["string","null"], "maxLength": 32},
    "app_version": {"type": ["string","null"], "maxLength": 32},
    "country": {"type": ["string","null"], "maxLength": 2},
    "revenue_amount": {"type": ["number","null"]},
    "revenue_currency": {"type": ["string","null"], "maxLength": 3},
    "props": {"type": ["object","null"], "additionalProperties": true}
  },
  "additionalProperties": true
}
