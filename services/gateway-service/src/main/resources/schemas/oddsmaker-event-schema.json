{
  "$id": "classpath:schemas/oddsmaker-event-schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Oddsmaker Event v1",
  "type": "object",
  "required": ["event_id", "game_id", "environment", "event_name", "device_id", "ts_client"],
  "properties": {
    "event_id": {"type": "string", "minLength": 8, "maxLength": 64},
    "game_id": {"type": "string", "minLength": 1, "maxLength": 64},
    "environment": {"type": "string", "minLength": 1, "maxLength": 32},
    "event_type": {"type": ["string", "null"], "maxLength": 32},
    "event_name": {"type": "string", "minLength": 1, "maxLength": 96},
    "user_id": {"type": ["string", "null"], "maxLength": 128},
    "device_id": {"type": "string", "minLength": 1, "maxLength": 128},
    "session_id": {"type": ["string", "null"], "maxLength": 128},
    "ts_client": {"oneOf": [ {"type": "string", "format": "date-time"}, {"type": "number"} ]},
    "ts_server": {"oneOf": [ {"type": "string", "format": "date-time"}, {"type": "number"}, {"type": "null"} ]},
    "platform": {"type": ["string","null"], "maxLength": 32},
    "app_version": {"type": ["string","null"], "maxLength": 32},
    "sdk_version": {"type": ["string","null"], "maxLength": 32},
    "country": {"type": ["string","null"], "maxLength": 2},
    "client_ip": {"type": ["string","null"], "maxLength": 64},
    "user_agent": {"type": ["string","null"], "maxLength": 512},
    "revenue_amount": {"type": ["number","null"]},
    "revenue_currency": {"type": ["string","null"], "maxLength": 3},
    "player_id": {"type": ["string", "null"], "maxLength": 128},
    "character_id": {"type": ["string", "null"], "maxLength": 128},
    "server_id": {"type": ["string", "null"], "maxLength": 64},
    "guild_id": {"type": ["string", "null"], "maxLength": 64},
    "match_id": {"type": ["string", "null"], "maxLength": 64},
    "level_id": {"type": ["string", "null"], "maxLength": 64},
    "game_mode": {"type": ["string", "null"], "maxLength": 32},
    "difficulty": {"type": ["string", "null"], "maxLength": 32},
    "progression_path": {"type": ["string", "null"], "maxLength": 128},
    "order_id": {"type": ["string", "null"], "maxLength": 64},
    "product_id": {"type": ["string", "null"], "maxLength": 64},
    "receipt_hash": {"type": ["string", "null"], "maxLength": 64},
    "virtual_currency": {"type": ["string", "null"], "maxLength": 32},
    "virtual_amount": {"type": ["number", "null"]},
    "item_id": {"type": ["string", "null"], "maxLength": 64},
    "resource_id": {"type": ["string", "null"], "maxLength": 64},
    "resource_amount": {"type": ["number", "null"]},
    "flow_type": {"type": ["string", "null"], "maxLength": 32},
    "operation_id": {"type": ["string", "null"], "maxLength": 64},
    "operation_type": {"type": ["string", "null"], "maxLength": 64},
    "ad_network": {"type": ["string", "null"], "maxLength": 32},
    "ad_placement": {"type": ["string", "null"], "maxLength": 64},
    "ad_format": {"type": ["string", "null"], "maxLength": 32},
    "ad_impression_id": {"type": ["string", "null"], "maxLength": 64},
    "risk_context": {"type": ["string", "null"], "maxLength": 256},
    "device_fingerprint": {"type": ["string", "null"], "maxLength": 256},
    "client_integrity": {"type": ["string", "null"], "maxLength": 512},
    "experiments": {"type": ["object", "null"], "additionalProperties": {"type": "string"}},
    "props": {"type": ["object","null"], "additionalProperties": true}
  },
  "additionalProperties": true
}
